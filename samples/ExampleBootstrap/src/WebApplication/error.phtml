<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <link rel="stylesheet" href="/css/bootstrap.min.css">
        <title>Bootstrap Example - DynamicalWeb</title>
    </head>

    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="/">DynamicalWeb</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link active" href="/">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/about">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/contact">Contact</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="container mt-5">
            <div class="jumbotron">
                <h1 class="display-4">Hello, world!</h1>
                <p class="lead">This is a simple Bootstrap example powered by DynamicalWeb.</p>
                <hr class="my-4">
                <p>Request Method: <strong><?= \DynamicalWeb\WebSession::getRequest()->getMethod()->value ?></strong></p>
                <p>Request Path: <strong><?= \DynamicalWeb\WebSession::getRequest()->getPath() ?></strong></p>
                <p>Request Host: <strong><?= \DynamicalWeb\WebSession::getRequest()->getHost() ?></strong></p>
                <a class="btn btn-primary btn-lg" href="/about" role="button">Learn more</a>
            </div>

            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Static Resources</h5>
                            <p class="card-text">CSS and JavaScript files are served automatically from the resources directory.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Dynamic Routes</h5>
                            <p class="card-text">Path parameters like /api/users/123 are automatically extracted.</p>
                            <a href="/api/users/42" class="btn btn-sm btn-outline-primary">Try API</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Request Object</h5>
                            <p class="card-text">Full request details available in templates via $request.</p>
                            <a href="/api/hello" class="btn btn-sm btn-outline-primary">Hello API</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="/js/bootstrap.bundle.min.js"></script>
    </body>
</html>