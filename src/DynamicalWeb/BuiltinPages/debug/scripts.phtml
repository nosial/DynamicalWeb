<?php use DynamicalWeb\WebSession; ?>
    <script>
        function switchTab(tabId, btn) {
            document.querySelectorAll('.dw-tab-content').forEach(function(t) { t.classList.remove('dw-active'); });
            document.querySelectorAll('.dw-tab-btn').forEach(function(b) { b.classList.remove('dw-active'); });
            document.getElementById('tab-' + tabId).classList.add('dw-active');
            btn.classList.add('dw-active');
            if (tabId === 'live') { startLivePolling(); }
            notifyParent();
        }

        function togglePanel() {
            var body = document.getElementById('panel-body');
            var icon = document.getElementById('toggle-icon');
            body.classList.toggle('dw-collapsed');
            icon.innerHTML = body.classList.contains('dw-collapsed') ? '&#9654;' : '&#9660;';
            notifyParent();
        }

        function notifyParent() {
            setTimeout(function() {
                if (window.parent && window.parent !== window) {
                    window.parent.postMessage({ type: 'dw-debug-resize', height: document.body.scrollHeight }, '*');
                }
            }, 0);
        }

        // ---- Live metrics polling ----
        <?php if (WebSession::get('dw_debug_stats_url')): ?>
        var liveStatsUrl  = <?= json_encode(WebSession::get('dw_debug_stats_url')) ?>;
        var liveMaxPoints = 30;
        var liveTimer     = null;
        var liveActive    = false;

        // Per-metric history buffers
        var histories = {
            mem:       [],
            peak:      [],
            opcacheHr: [],
            opcacheMem:[],
            disk:      [],
            load:      [],
            apcuHr:    [],
            apcuMem:   [],
        };

        function fmtBytes(b) {
            if (b >= 1073741824) return (b / 1073741824).toFixed(1) + ' GB';
            if (b >= 1048576)    return (b / 1048576).toFixed(1) + ' MB';
            if (b >= 1024)       return (b / 1024).toFixed(1) + ' KB';
            return b + ' B';
        }

        function setFill(id, pct) {
            var el = document.getElementById(id);
            if (el) el.style.width = Math.min(100, Math.max(0, pct)) + '%';
        }

        function setText(id, html) {
            var el = document.getElementById(id);
            if (el) el.innerHTML = html;
        }

        function pushHistory(key, value) {
            histories[key].push(value);
            if (histories[key].length > liveMaxPoints) histories[key].shift();
        }

        /**
         * Draw a sparkline into a canvas element.
         * @param {string} canvasId   - canvas element id
         * @param {string} msgId      - overlay message element id
         * @param {number[]} data     - data points
         * @param {number} maxVal     - value at 100% height (0 means auto)
         * @param {string} lineColor  - stroke / fill colour (hex)
         * @param {function} labelFn  - fn(latestValue) => string label shown top-right
         */
        function drawChart(canvasId, msgId, data, maxVal, lineColor, labelFn) {
            var canvas = document.getElementById(canvasId);
            var msg    = document.getElementById(msgId);
            if (!canvas) return;
            canvas.width = canvas.offsetWidth || 200;
            var ctx = canvas.getContext('2d');
            var w = canvas.width, h = canvas.height;
            ctx.clearRect(0, 0, w, h);
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(0, 0, w, h);

            if (msg) msg.style.display = data.length >= 2 ? 'none' : '';
            if (data.length < 2) return;

            var hi = maxVal > 0 ? maxVal : (Math.max.apply(null, data) * 1.2 || 1);

            // Grid lines
            ctx.strokeStyle = '#e2e8f0';
            ctx.lineWidth = 1;
            for (var g = 1; g < 4; g++) {
                var gy = Math.round(h * g / 4) + 0.5;
                ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(w, gy); ctx.stroke();
            }

            var pts = data.map(function(v, i) {
                return {
                    x: Math.round(i / (liveMaxPoints - 1) * w),
                    y: Math.round(h - (v / hi) * (h - 8) - 4)
                };
            });

            // Area fill
            var r = parseInt(lineColor.slice(1,3),16),
                g2= parseInt(lineColor.slice(3,5),16),
                b = parseInt(lineColor.slice(5,7),16);
            ctx.beginPath();
            ctx.moveTo(pts[0].x, h);
            pts.forEach(function(p) { ctx.lineTo(p.x, p.y); });
            ctx.lineTo(pts[pts.length-1].x, h);
            ctx.closePath();
            ctx.fillStyle = 'rgba('+r+','+g2+','+b+',0.18)';
            ctx.fill();

            // Line
            ctx.beginPath();
            ctx.moveTo(pts[0].x, pts[0].y);
            pts.forEach(function(p) { ctx.lineTo(p.x, p.y); });
            ctx.strokeStyle = lineColor;
            ctx.lineWidth = 1.5;
            ctx.stroke();

            // Label
            if (labelFn) {
                ctx.fillStyle = lineColor;
                ctx.font = '9px Verdana,Arial,sans-serif';
                ctx.textAlign = 'right';
                ctx.fillText(labelFn(data[data.length-1]), w - 3, 10);
            }
        }

        function applyStats(s) {
            var memPct  = s.memory.usage_pct || 0;
            var peakPct = s.memory.peak_pct  || 0;

            // Memory
            setFill('live-mem-fill',  memPct);
            setText('live-mem-val',   fmtBytes(s.memory.usage) + ' <span style="color:#888;">of ' + fmtBytes(s.memory.limit) + ' (' + memPct + '%)</span>');
            setFill('live-peak-fill', peakPct);
            setText('live-peak-val',  fmtBytes(s.memory.peak) + ' <span style="color:#888;">(' + peakPct + '%)</span>');

            // Load
            setText('live-load', s.load.avg1 + ' &nbsp;/&nbsp; ' + s.load.avg5 + ' &nbsp;/&nbsp; ' + s.load.avg15);

            // Disk
            if (s.disk.used_pct !== null) {
                setFill('live-disk-fill', s.disk.used_pct);
                setText('live-disk-val',
                    fmtBytes(s.disk.total - s.disk.free) + ' used' +
                    ' <span style="color:#888;">of ' + fmtBytes(s.disk.total) + ' (' + s.disk.used_pct + '%)</span>');
            } else {
                setText('live-disk-val', 'N/A');
            }

            // OPcache
            if (s.opcache && s.opcache.enabled) {
                setFill('live-opcache-fill', s.opcache.hit_rate);
                setText('live-opcache-val',  s.opcache.hit_rate + '%');
                setText('live-scripts',      s.opcache.cached_scripts + ' scripts');
                setFill('live-opcache-mem-fill',    s.opcache.mem_pct || 0);
                setText('live-opcache-mem-val',     fmtBytes(s.opcache.used_memory) + ' <span style="color:#888;">of ' + fmtBytes(s.opcache.total_memory) + ' (' + (s.opcache.mem_pct || 0) + '%)</span>');
                setFill('live-opcache-wasted-fill',  s.opcache.wasted_pct || 0);
                setText('live-opcache-wasted-val',   fmtBytes(s.opcache.wasted_memory) + ' <span style="color:#888;">(' + (s.opcache.wasted_pct || 0) + '%)</span>');
                setText('live-opcache-mem',  fmtBytes(s.opcache.used_memory) + ' used / ' + fmtBytes(s.opcache.free_memory) + ' free');
            } else {
                setText('live-opcache-val',          'Disabled');
                setText('live-opcache-mem-val',      'N/A');
                setText('live-opcache-wasted-val',   'N/A');
                setText('live-scripts',              'N/A');
                setText('live-opcache-mem',          'N/A');
            }

            // APCu
            var apcuSection = document.getElementById('live-apcu-section');
            if (s.apcu && s.apcu.enabled) {
                if (apcuSection) apcuSection.style.display = '';
                setFill('live-apcu-hr-fill',  s.apcu.hit_rate);
                setText('live-apcu-hr-val',   s.apcu.hit_rate + '%');
                setText('live-apcu-entries',  s.apcu.entries + ' entries');
                setFill('live-apcu-mem-fill', s.apcu.mem_pct || 0);
                setText('live-apcu-mem-val',  fmtBytes(s.apcu.used_memory) + ' <span style="color:#888;">of ' + fmtBytes(s.apcu.total_memory) + ' (' + (s.apcu.mem_pct || 0) + '%)</span>');
                setText('live-apcu-hits',     s.apcu.hits + ' hits / ' + s.apcu.misses + ' misses');
            } else {
                if (apcuSection) apcuSection.style.display = 'none';
            }

            setText('live-files', s.php.included_files + ' files');

            // Push to history buffers
            pushHistory('mem',        s.memory.usage);
            pushHistory('peak',       s.memory.peak);
            pushHistory('opcacheHr',  (s.opcache && s.opcache.enabled) ? s.opcache.hit_rate  : 0);
            pushHistory('opcacheMem', (s.opcache && s.opcache.enabled) ? s.opcache.mem_pct   : 0);
            pushHistory('disk',       (s.disk.used_pct !== null)       ? s.disk.used_pct      : 0);
            pushHistory('load',       s.load.avg1);
            if (s.apcu && s.apcu.enabled) {
                pushHistory('apcuHr',  s.apcu.hit_rate);
                pushHistory('apcuMem', s.apcu.mem_pct || 0);
            }

            // Redraw charts
            var memLimit = s.memory.limit > 0 ? s.memory.limit : 0;
            drawChart('chart-mem',        'chart-mem-msg',        histories.mem,        memLimit,  '#3d6b9e', fmtBytes);
            drawChart('chart-peak',       'chart-peak-msg',       histories.peak,       memLimit,  '#b08040', fmtBytes);
            drawChart('chart-opcache-hr', 'chart-opcache-hr-msg', histories.opcacheHr,  100,       '#7a6aaa', function(v){ return v + '%'; });
            drawChart('chart-opcache-mem','chart-opcache-mem-msg',histories.opcacheMem, 100,       '#5b86b5', function(v){ return v + '%'; });
            drawChart('chart-disk',       'chart-disk-msg',       histories.disk,       100,       '#5a9b5a', function(v){ return v + '%'; });
            drawChart('chart-load',       'chart-load-msg',       histories.load,       0,         '#4a5568', function(v){ return v.toFixed(2); });

            // APCu charts — show cells only when APCu is active
            var apcuHrCell  = document.getElementById('chart-apcu-hr-cell');
            var apcuMemCell = document.getElementById('chart-apcu-mem-cell');
            if (s.apcu && s.apcu.enabled) {
                if (apcuHrCell)  apcuHrCell.style.display  = '';
                if (apcuMemCell) apcuMemCell.style.display = '';
                drawChart('chart-apcu-hr',  'chart-apcu-hr-msg',  histories.apcuHr,  100, '#3d8a6b', function(v){ return v + '%'; });
                drawChart('chart-apcu-mem', 'chart-apcu-mem-msg', histories.apcuMem, 100, '#6a4aaa', function(v){ return v + '%'; });
            } else {
                if (apcuHrCell)  apcuHrCell.style.display  = 'none';
                if (apcuMemCell) apcuMemCell.style.display = 'none';
            }

            // Status dot
            var dot = document.getElementById('live-status');
            if (dot) dot.innerHTML = '<span style="color:#27ae60;">&#9679;</span> Updated ' + new Date(s.timestamp).toLocaleTimeString();

            notifyParent();
        }

        function fetchLiveStats() {
            fetch(liveStatsUrl, { cache: 'no-store' })
                .then(function(r) { return r.ok ? r.json() : Promise.reject('HTTP ' + r.status); })
                .then(function(data) { applyStats(data); })
                .catch(function(err) {
                    var dot = document.getElementById('live-status');
                    if (dot) dot.innerHTML = '<span style="color:#cc0000;">&#9679;</span> Error: ' + err;
                });
        }

        function startLivePolling() {
            if (liveActive) return;
            liveActive = true;
            fetchLiveStats();
            liveTimer = setInterval(fetchLiveStats, 2000);
        }
        <?php endif; ?>

        window.addEventListener('load', notifyParent);

        // Cookie editor
        document.addEventListener('click', function(e) {
            var btn = e.target;
            if (!btn || !btn.dataset) return;
            var action = btn.dataset.action;

            if (btn.classList && btn.classList.contains('dw-btn-edit')) {
                var id = btn.dataset.safeid;
                document.getElementById(id + '-view').style.display = 'none';
                var form = document.getElementById(id + '-edit');
                if (form) { form.style.display = 'block'; form.querySelector('.dw-input') && form.querySelector('.dw-input').focus(); }

            } else if (action === 'cancel-ck') {
                var id = btn.dataset.safeid;
                document.getElementById(id + '-view').style.display = 'flex';
                document.getElementById(id + '-edit').style.display = 'none';

            } else if (action === 'save-ck') {
                var id  = btn.dataset.safeid;
                var nm  = btn.dataset.name;
                dwSendCookie({
                    name:     nm,
                    value:    document.getElementById(id + '-val').value,
                    path:     document.getElementById(id + '-path').value    || '/',
                    domain:   document.getElementById(id + '-domain').value  || '',
                    samesite: document.getElementById(id + '-samesite').value || 'Lax',
                    secure:   document.getElementById(id + '-secure').checked,
                    session:  document.getElementById(id + '-session').checked,
                    expires:  document.getElementById(id + '-expires').value  || ''
                });

            } else if (action === 'del-ck') {
                dwSendCookie({ name: btn.dataset.name, del: true, path: '/' });
            }
        });

        function dwCkToggleExpires(cb, inputId) {
            var inp = document.getElementById(inputId);
            if (inp) inp.disabled = cb.checked;
        }

        function dwAddCookie() {
            var name = (document.getElementById('dw-ck-new-name')  || {}).value || '';
            if (!name.trim()) { var n = document.getElementById('dw-ck-new-name'); if (n) n.focus(); return; }
            dwSendCookie({
                name:     name.trim(),
                value:    (document.getElementById('dw-ck-new-value')    || {}).value || '',
                path:     (document.getElementById('dw-ck-new-path')     || {}).value || '/',
                domain:   (document.getElementById('dw-ck-new-domain')   || {}).value || '',
                samesite: (document.getElementById('dw-ck-new-samesite') || {}).value || 'Lax',
                secure:   (document.getElementById('dw-ck-new-secure')   || {}).checked || false,
                session:  (document.getElementById('dw-ck-new-session')  || {}).checked !== false,
                expires:  (document.getElementById('dw-ck-new-expires')  || {}).value || ''
            });
        }

        function dwSendCookie(opts) {
            // Send cookie data to parent (srcdoc iframe has null origin, parent must set the cookie)
            if (window.parent && window.parent !== window) {
                window.parent.postMessage({ type: 'dw-debug-set-cookie', opts: opts }, '*');
            } else {
                dwApplyCookie(opts);
            }
        }

        function dwApplyCookie(opts) {
            fetch('/dynaweb/debug/cookie', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(opts)
            }).then(function() {
                window.location.reload();
            }).catch(function() {
                window.location.reload();
            });
        }

        function dwCookieReload() {
            if (window.parent && window.parent !== window) {
                window.parent.postMessage({ type: 'dw-debug-reload' }, '*');
            } else {
                window.location.reload();
            }
        }
    </script>
