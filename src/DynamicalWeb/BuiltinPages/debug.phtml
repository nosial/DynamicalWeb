        .dw-toggle-icon { float: right; font-size: 11px; color: #ffffff; }
        .dw-body.dw-collapsed { display: none; }

        /* Tab bar */
        .dw-tab-bar {
            background: #c4cdd7;
            border-bottom: 2px solid #5b7fa6;
            padding: 4px 8px 0 8px;
            display: flex;
            gap: 3px;
            margin: 0;
            overflow-x: auto;
            white-space: nowrap;
            flex-wrap: nowrap;
