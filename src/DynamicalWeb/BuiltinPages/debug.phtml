        .dw-profiler-col-pct { white-space: nowrap; min-width: 90px; }
        .dw-profiler-path { font-family: 'Courier New', monospace; font-size: 10px; color: #333; word-break: break-all; }
        .dw-profiler-bar-track { height: 5px; background: #dce4ec; border: 1px solid #c0c8d0; margin-bottom: 2px; }
