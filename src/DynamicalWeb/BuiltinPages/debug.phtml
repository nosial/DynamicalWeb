        .dw-route-method-post   { background:#2980b9; }
        .dw-route-method-put    { background:#8e44ad; }
        .dw-route-method-patch  { background:#e67e22; }
        .dw-route-method-delete { background:#c0392b; }
        .dw-route-method-head   { background:#7f8c8d; }
        .dw-route-method-options{ background:#7f8c8d; }
        .dw-route-method-any    { background:#555; }
        .dw-route-locale {
            display:inline-block; margin-left:6px; padding:1px 4px;
            background:#c4cdd7; color:#2c4a6b; font-size:9px; border-radius:2px;
        }


        /* Info table */
        .dw-content-table { width: 100%; border-collapse: collapse; background: #ffffff; }
        .dw-content-table tr:nth-child(even) td { background: #f7f9fb; }
        .dw-content-table td {
            padding: 7px 12px;
            border-bottom: 1px solid #dde3ea;
            font-size: 11px;
            vertical-align: top;
        }
        .dw-label {
            color: #2c4a6b;
            font-weight: bold;
            width: 130px;
            white-space: nowrap;
            border-right: 1px solid #dde3ea;
        }
        .dw-value { color: #333333; }
        .dw-value-empty { color: #aab3be; font-style: italic; }
        .dw-status-success { color: #27ae60; font-weight: bold; }
        .dw-status-error   { color: #cc0000; font-weight: bold; }
        .dw-status-warning { color: #e67e22; font-weight: bold; }

        /* Section headers inside tabs */
        .dw-section-divider {
            background: linear-gradient(to bottom, #d4dce5 0%, #c4cdd7 100%);
