        /* Params */
        .dw-param-item {
            padding: 6px 12px;
            border-bottom: 1px solid #eaecee;
            display: flex;
            font-size: 11px;
        }
        .dw-param-item:last-child { border-bottom: none; }
        .dw-param-item:nth-child(even) { background: #f7f9fb; }
        .dw-param-key  {
            color: #2c4a6b;
            font-weight: bold;
            min-width: 200px;
            flex-shrink: 0;
            border-right: 1px solid #dde3ea;
            padding-right: 10px;
            margin-right: 10px;
        }
        .dw-param-value {
            color: #333333;
            word-break: break-all;
            font-family: 'Courier New', monospace;
            font-size: 10px;
        }

        /* Profiler table */
        .dw-profiler-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }
        .dw-profiler-table thead tr {
            background: linear-gradient(to bottom, #d4dce5 0%, #c4cdd7 100%);
            border-bottom: 1px solid #9badbd;
        }
        .dw-profiler-table thead th {
