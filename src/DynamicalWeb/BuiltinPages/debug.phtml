            color: #2c4a6b;
            margin-bottom: 6px;
            padding-bottom: 4px;
            border-bottom: 1px solid #c4cdd7;
        }
        .dw-ck-form-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 5px 10px;
            margin-bottom: 6px;
        }
        .dw-ck-field { display: flex; flex-direction: column; gap: 2px; }
        .dw-ck-field.dw-col-span-2 { grid-column: span 2; }
        .dw-ck-label {
            font-family: Verdana, Arial, Helvetica, sans-serif;
            font-size: 9px;
            font-weight: bold;
            color: #2c4a6b;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .dw-ck-check {
            font-family: Verdana, Arial, Helvetica, sans-serif;
            font-size: 10px;
            color: #333;
            cursor: pointer;
        }
        .dw-ck-note {
            font-family: Verdana, Arial, Helvetica, sans-serif;
            font-size: 9px;
            color: #999;
            font-style: italic;
            align-self: center;
        }
        .dw-ck-form-actions {
            display: flex;
            gap: 5px;
            padding-top: 4px;
            border-top: 1px solid #c4cdd7;
        }
    </style>
